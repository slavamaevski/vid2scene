{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "CameraData",
    "type": "object",
    "properties": {
        "lookAt": {
            "type": "object",
            "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "z": { "type": "number" }
            },
            "required": ["x", "y", "z"],
            "additionalProperties": false
        },
        "position": {
            "type": "object",
            "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "z": { "type": "number" }
            },
            "required": ["x", "y", "z"],
            "additionalProperties": false
        },
        "up": {
            "type": "object",
            "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "z": { "type": "number" }
            },
            "required": ["x", "y", "z"],
            "additionalProperties": false
        },
        "cameraType": {
            "type": "string",
            "enum": ["orbital", "drone"]
        }
    },
    "required": ["lookAt", "position", "up"],
    "additionalProperties": false
}