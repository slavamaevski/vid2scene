# vid2scene self-host configuration.
# Copy to ".env" (same directory as docker-compose.selfhost.yaml) and edit.
# Every value has a working default, so the stack runs even with an empty .env.

# --- Django ---
# Generate a real one for any non-localhost deployment:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=dev-insecure-change-me-before-exposing

# Billing is OFF by default: no Stripe needed, every user gets full access.
# Set to "true" (and provide STRIPE_SECRET_KEY to the containers) to enable it.
BILLING_ENABLED=false

# --- Postgres (shared by web + worker) ---
POSTGRES_DB=vid2scene
POSTGRES_USER=vid2scene
POSTGRES_PASSWORD=vid2scene

# --- First-run admin user (created automatically by the web container) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin

# --- Worker ---
# Hugging Face token (https://huggingface.co/settings/tokens). Required ONLY if
# you intend to use:
#   - reconstruction_method=vggt → uses facebook/VGGT-1B-Commercial (gated)
#   - equirectangular/pano with background removal → uses facebook/sam3 (gated)
# The default reconstruction_method=glomap needs no models and no HF_TOKEN.
# Before first use of a gated repo, sign in on huggingface.co and click "agree
# to license" on each repo page. Downloads are cached in the hf-cache volume.
HF_TOKEN=
# Which RQ queues the worker consumes (space-separated).
RQ_QUEUES=internal enterprise high default

# --- Public-facing identity (all optional) ---
# Contact email shown in the UI/footer/docs.
CONTACT_EMAIL=contact@example.com
# Canonical site URL used in API-doc examples, emails, and SEO tags.
# SITE_URL=http://localhost:8000
# Umami analytics: leave blank to disable (no tracker is rendered).
UMAMI_WEBSITE_ID=
# UMAMI_SRC=https://cloud.umami.is/script.js
# Base URL the landing-page hero video is served from. Blank = no video.
LANDING_VIDEO_BASE_URL=
